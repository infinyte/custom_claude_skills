  "triggers": {
    "explicit": [
      "Create a portfolio site for my GitHub repo",
      "Generate a GitHub Pages website from this repository",
      "Make a portfolio website from my GitHub project",
      "Build a showcase website for my GitHub repo",
      "Create a professional site to showcase my code"
    ],
    "implicit": [
      "how can I best showcase this project",
      "make my GitHub work look professional",
      "I want people to see what my project does",
      "create documentation for my GitHub project visually"
    ],
    "interview": [
      "portfolio for my GitHub projects",
      "showcase my work to recruiters",
      "impressive GitHub presence for interviews",
      "interview preparation from my code projects"
    ]
  },
  "capabilities": {
    "projectTypeDetection": [
      "TypeScript/Node.js",
      ".NET/C#",
      "Python/ML/Computer Vision",
      "Full-Stack Web Applications"
