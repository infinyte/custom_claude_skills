  "installation": {
    "method": "direct",
    "steps": [
      "1. Extract skill files to your skills directory",
      "2. Ensure all supporting materials are included",
      "3. Update Claude's skill registry with skill-manifest.json",
      "4. Test by providing a GitHub repository URL"
    ],
    "location": "/mnt/skills/user/github-pages-generator"
  },
