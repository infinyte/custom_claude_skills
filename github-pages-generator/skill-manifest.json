      "Image optimization",
      "Automatic sitemap generation"
    ],
    "outputFormats": [
      "HTML5",
      "CSS3",
      "JavaScript",
      "GitHub Actions YAML",
      "Configuration JSON"
    ]
  },
  "deliverables": {
